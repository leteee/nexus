__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version # pyenv

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Test and coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# Documentation
docs/_build/
# Auto-generated API documentation (use 'nexus doc' to regenerate)
docs/api/
/site # mkdocs

# Jupyter Notebook & IPython
.ipynb_checkpoints/
profile_default/
ipython_config.py

# PyInstaller
*.manifest
*.spec

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# PEP 582 (pyflow)
__pypackages__/

# IDEs and Editors
.vscode/
.idea/
.spyderproject/
.spyproject/
.ropeproject/
*.swp
*.swo
*~

# OS specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Project-specific
# Local configuration (user-specific overrides)
config/local.yaml
config/setting-local.yaml
# Cases: ignore all generated files and user data
cases/
workspace/cases/
# User workspace (sideloaded packages)
nexus_workspace/
# Claude Code configuration (user-specific)
.claude/
